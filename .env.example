# DataHub GraphQL endpoint
DATAHUB_GMS_URL=http://localhost:8080/api/graphql

# Optional bearer token for authenticated DataHub instances
DATAHUB_ACCESS_TOKEN=

# PostgREST endpoint (run on port 3001 to avoid conflict with metadata-api on 3000)
POSTGREST_URL=http://localhost:3001

# Optional bearer token for authenticated PostgREST instances
POSTGREST_ACCESS_TOKEN=

# Postgres connection for table metadata
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/kpu_opendata

# Application
NODE_ENV=development
PORT=3000
